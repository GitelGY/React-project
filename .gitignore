# Dependencies - אלפי קבצים שנוצרים מהתקנה
node_modules/

# Production - תיקיות הבנייה הסופית
build/
dist/

# Environment - קבצי סביבה עם סודות (חשוב מאוד!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs - קבצי שגיאות שנשמרים במחשב
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor settings - הגדרות אישיות של VS Code
.vscode/
.idea/
*.suo
*.ntvs*

# OS files - קבצי מערכת הפעלה מיותרים
DS_Store
thumbs.db